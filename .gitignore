# ─── Secrets ──────────────────────────────────────────────────────
.env
*.key
*.pem
*.p12
secrets/

# ─── Python ───────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.Python
env/
venv/
.venv/
ENV/
pip-wheel-metadata/
.pytest_cache/
.coverage
htmlcov/
